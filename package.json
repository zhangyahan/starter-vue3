{
  "name": "pkg-name",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@10.30.3",
  "author": "Yahan Zhang <yahan.zg@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/zhangyahan/pkg-name#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangyahan/pkg-name.git"
  },
  "bugs": "https://github.com/zhangyahan/pkg-name/issues",
  "engines": {
    "node": ">=20.20.0"
  },
  "scripts": {
    "prepare": "npx simple-git-hooks",
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/node": "^25.3.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "eslint-plugin-format": "^2.0.1",
    "less": "^4.5.1",
    "lint-staged": "^16.3.1",
    "postcss-html": "^1.8.1",
    "postcss-less": "^6.0.0",
    "postcss-scss": "^4.0.9",
    "sass": "^1.85.0",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.4.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-rational-order": "^0.1.2",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-less": "^4.0.0",
    "stylelint-order": "^7.0.1",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "preserveUnused": [
      "commit-msg"
    ]
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,vue,html}": [
      "eslint --fix"
    ],
    "*.{html,vue}": [
      "stylelint --fix"
    ],
    "*.{css,less,scss}": [
      "stylelint --fix"
    ]
  }
}
